{% extends 'base.html.twig' %}

{% form_theme form with ['form/template.html.twig'] %}

{% block title %}{{ is_create ? 'Proposer un trajet' : 'Modifier le trajet' }} — EcoRide{% endblock %}

{% block body %}
<div class="page-wrapper">

  <div class="text-center mb-4">
    <i data-lucide="route" style="width:48px;height:48px;stroke:var(--eco-secondary);"></i>
    <h1 style="font-size: 1.8rem;" class="mb-1 mt-2">
      {{ is_create ? 'Proposer un trajet' : 'Modifier le trajet' }}
    </h1>
    <p class="text-muted" style="font-size: 0.9rem;">
      {{ is_create ? 'Partagez votre route et gagnez des crédits.' : 'Mettez à jour les informations du trajet.' }}
    </p>
  </div>

  <div style="max-width: 680px; margin: 0 auto;">
    <div class="card p-4">
      {{ form_start(form) }}

      <h6 class="mb-3 d-flex align-items-center gap-2" style="color: var(--eco-primary); font-weight: 600;">
        <i data-lucide="map-pin" class="icon-md"></i>Départ
      </h6>
      <div class="row g-3 mb-4">
        <div class="col-sm-6">{{ form_row(form.lieu_depart) }}</div>
        <div class="col-sm-3">{{ form_row(form.date_depart) }}</div>
        <div class="col-sm-3">{{ form_row(form.heure_depart) }}</div>
      </div>

      <h6 class="mb-3 d-flex align-items-center gap-2" style="color: var(--eco-primary); font-weight: 600;">
        <i data-lucide="flag" class="icon-md"></i>Arrivée
      </h6>
      <div class="row g-3 mb-4">
        <div class="col-sm-6">{{ form_row(form.lieu_arrivee) }}</div>
        <div class="col-sm-3">{{ form_row(form.date_arrivee) }}</div>
        <div class="col-sm-3">{{ form_row(form.heure_arrivee) }}</div>
      </div>

      <h6 class="mb-3 d-flex align-items-center gap-2" style="color: var(--eco-primary); font-weight: 600;">
        <i data-lucide="settings" class="icon-md"></i>Détails
      </h6>
      <div class="row g-3 mb-4">
        <div class="col-sm-6">{{ form_row(form.nb_place) }}</div>
        <div class="col-sm-6">{{ form_row(form.prix_personne) }}</div>
      </div>

      {{ form_rest(form) }}

      <div class="d-flex gap-2 mt-2">
        <button type="submit" class="btn btn-success flex-grow-1 d-flex align-items-center justify-content-center gap-2">
          <i data-lucide="{{ is_create ? 'plus' : 'save' }}" class="icon-sm"></i>
          {{ is_create ? 'Publier le trajet' : 'Sauvegarder' }}
        </button>
        <a href="{{ path('user_profile') }}" class="btn btn-outline-secondary d-flex align-items-center gap-1">
          <i data-lucide="x" class="icon-sm"></i>Annuler
        </a>
      </div>

      {{ form_end(form) }}
    </div>
  </div>

</div>
{% endblock %}
