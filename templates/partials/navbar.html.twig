    <div class="offcanvas-header border-bottom border-secondary">
      <h5 class="offcanvas-title" id="offcanvasMenuLabel">
        🌿 <span style="color: var(--eco-light);">Eco</span>Ride
      </h5>
      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="offcanvas"
        aria-label="Close"
      ></button>
    </div>
    <div class="offcanvas-body">

      <ul class="nav flex-column mb-3">
        <li class="nav-item">
          <a class="nav-link py-2" href="{{ path('index') }}">🏠 Accueil</a>
        </li>
        <li class="nav-item">
          <a class="nav-link py-2" href="{{ path('covoiturage_list') }}">🚗 Covoiturages</a>
        </li>
        <li class="nav-item">
          <a class="nav-link py-2" href="{{ path('contact') }}">📬 Contact</a>
        </li>
        <li class="nav-item">
          <a class="nav-link py-2" href="{{ path('about') }}">ℹ️ À propos</a>
        </li>
        <li class="nav-item">
          <a class="nav-link py-2" href="{{ path('avis_list') }}">⭐ Avis</a>
        </li>
      </ul>

