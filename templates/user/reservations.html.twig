{% extends 'base.html.twig' %}

{% block title %}Mes réservations — EcoRide{% endblock %}

{% block body %}
<div class="page-wrapper">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h1 class="mb-0 d-flex align-items-center gap-2" style="font-size: 1.8rem;">
        <i data-lucide="calendar" style="width:28px;height:28px;stroke:var(--eco-secondary);"></i>Mes réservations
      </h1>
      <p class="text-muted mb-0" style="font-size: 0.9rem;">Vos trajets réservés en tant que passager</p>
    </div>
    <a href="{{ path('covoiturage_list') }}" class="btn btn-success d-flex align-items-center gap-2">
      <i data-lucide="search" class="icon-sm"></i>Chercher un trajet
    </a>
  </div>

  {% if participations is empty %}
    <div class="card p-5 text-center">
      <i data-lucide="calendar" style="width:56px;height:56px;stroke:var(--eco-border);margin-bottom:1rem;"></i>
      <h5 class="mb-2">Aucune réservation</h5>
      <p class="text-muted mb-4">Vous n'avez pas encore réservé de trajet.</p>
      <a href="{{ path('covoiturage_list') }}" class="btn btn-success mx-auto d-flex align-items-center gap-2" style="max-width: 220px;">
        <i data-lucide="search" class="icon-sm"></i>Trouver un trajet
      </a>
    </div>
  {% else %}
    <div class="d-flex flex-column gap-3">
      {% for p in participations %}
        <div class="card p-3">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
              <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                   style="width:48px;height:48px;background:var(--eco-mint);border:2px solid var(--eco-secondary);">
                <i data-lucide="car" style="width:22px;height:22px;stroke:var(--eco-primary);"></i>
              </div>
              <div>
                <div class="fw-semibold">
                  {{ p.covoiturage.lieuDepart }}
                  <span style="color: var(--eco-secondary);">→</span>
                  {{ p.covoiturage.lieuArrivee }}
                </div>
                <div class="text-muted d-flex align-items-center gap-2" style="font-size: 0.82rem;">
                  <i data-lucide="calendar" class="icon-xs"></i>{{ p.covoiturage.dateDepart|date('d/m/Y') }}
                  &nbsp;·&nbsp;
                  <i data-lucide="user" class="icon-xs"></i>{{ p.covoiturage.createdBy.username }}
                </div>
                <div class="text-muted" style="font-size: 0.78rem;">
                  Réservé le {{ p.dateParticipation|date('d/m/Y à H:i') }}
                </div>
              </div>
            </div>
            <a href="{{ path('covoiturage_show', {id: p.covoiturage.id}) }}" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
              <i data-lucide="eye" class="icon-xs"></i>Voir le trajet
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endblock %}
