{% extends 'base.html.twig' %}

{% block title %}Avis des utilisateurs — EcoRide{% endblock %}

{% block body %}
<div class="page-wrapper">

  {% set total = 0 %}
  {% for a in avis %}
    {% set total = total + a.note %}
  {% endfor %}
  {% set moyenne = avis|length > 0 ? (total / avis|length)|number_format(1) : null %}

  <div class="text-center mb-5">
    <i data-lucide="star" style="width:48px;height:48px;stroke:#f59e0b;fill:#f59e0b;"></i>
    <h1 class="mb-2 mt-2">Avis de la communauté</h1>
    <p class="text-muted" style="max-width: 500px; margin: 0 auto;">
      Ce que les membres pensent de leurs expériences EcoRide.
    </p>
  </div>

  {% if moyenne %}
    <div class="card p-4 mb-5 text-center" style="max-width: 360px; margin: 0 auto 2rem;">
      <div style="font-size: 3rem; font-weight: 700; color: var(--eco-primary);">{{ moyenne }}</div>
      <div class="mb-2">
        {% for i in 1..5 %}
          <i data-lucide="star" style="width:22px;height:22px;stroke:#f59e0b;{{ i <= moyenne|round ? 'fill:#f59e0b;' : '' }}"></i>
        {% endfor %}
      </div>
      <div class="text-muted" style="font-size: 0.85rem;">Note moyenne sur {{ avis|length }} avis</div>
    </div>
  {% else %}
    <div class="card p-5 text-center mb-5">
      <i data-lucide="star" style="width:48px;height:48px;stroke:var(--eco-border);margin-bottom:0.5rem;"></i>
      <p class="text-muted mb-0">Aucun avis pour le moment.</p>
    </div>
  {% endif %}

  {% if avis is not empty %}
    <div class="row g-4">
      {% for a in avis %}
        <div class="col-md-6 col-lg-4">
          <div class="card p-4 h-100">
            <div class="mb-2">
              {% for i in 1..5 %}
                <i data-lucide="star" style="width:16px;height:16px;stroke:#f59e0b;{{ i <= a.note ? 'fill:#f59e0b;' : '' }}"></i>
              {% endfor %}
              <span class="fw-semibold ms-1">{{ a.note }}/5</span>
            </div>
            <blockquote class="mb-3 fst-italic text-muted" style="font-size: 0.9rem; border-left: 3px solid var(--eco-secondary); padding-left: 0.8rem; margin: 0 0 0.8rem;">
              "{{ a.commentaire }}"
            </blockquote>
            <div class="mt-auto d-flex align-items-center gap-2">
              <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                   style="width:32px;height:32px;background:var(--eco-mint);">
                <i data-lucide="user" style="width:16px;height:16px;stroke:var(--eco-primary);"></i>
              </div>
              <span class="fw-semibold" style="font-size: 0.88rem;">{{ a.user.firstname }}</span>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endblock %}
