{% extends 'base.html.twig' %}

{% block title %}À propos - EcoRide{% endblock %}

{% block body %}
<div class="page-wrapper">

  <div class="text-center mb-5">
    <h1 class="mb-2">À propos d'EcoRide</h1>
    <p class="lead text-muted" style="max-width: 600px; margin: 0 auto;">
      Une plateforme de covoiturage écologique pensée pour favoriser les trajets partagés et encourager une mobilité responsable.
    </p>
  </div>

  <div class="row g-4 mb-5">
    <div class="col-md-4">
      <div class="card p-4 text-center h-100">
        <div style="margin-bottom: 1rem;">
          <i data-lucide="car" style="width:40px;height:40px;stroke:var(--eco-secondary);"></i>
        </div>
        <h5>Moins de voitures</h5>
        <p class="text-muted mb-0">Moins de véhicules sur les routes, moins d'embouteillages et une empreinte carbone réduite pour tous.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card p-4 text-center h-100">
        <div style="margin-bottom: 1rem;">
          <i data-lucide="banknote" style="width:40px;height:40px;stroke:var(--eco-secondary);"></i>
        </div>
        <h5>Économies partagées</h5>
        <p class="text-muted mb-0">Conducteurs et passagers partagent les frais. Chaque trajet devient plus économique pour tout le monde.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card p-4 text-center h-100">
        <div style="margin-bottom: 1rem;">
          <i data-lucide="sprout" style="width:40px;height:40px;stroke:var(--eco-secondary);"></i>
        </div>
        <h5>Impact positif</h5>
        <p class="text-muted mb-0">Chaque covoiturage compte. En voyageant ensemble, vous contribuez activement à la protection de la planète.</p>
      </div>
    </div>
  </div>

  <div class="section-box">
    <div class="row align-items-center g-4">
      <div class="col-md-6">
        <h2 class="mb-3">Notre mission</h2>
        <p>
          <strong>EcoRide</strong> met en relation conducteurs et passagers pour optimiser les déplacements du quotidien. Nous croyons que chaque trajet compte et que voyager ensemble est la clé d'un avenir plus durable.
        </p>
        <p class="mb-4">
          Rejoignez notre communauté et participez à une nouvelle manière de voyager — plus solidaire, plus économique, plus verte.
        </p>
        <a href="{{ path('app_register') }}" class="btn btn-success px-4">
          <i data-lucide="user-plus" class="icon-sm me-2"></i>Rejoindre EcoRide
        </a>
      </div>
      <div class="col-md-6 text-center">
        <i data-lucide="globe" style="width:80px;height:80px;stroke:var(--eco-secondary);"></i>
        <p class="text-muted mt-3">Ensemble, changeons nos habitudes</p>
      </div>
    </div>
  </div>

</div>
{% endblock %}
