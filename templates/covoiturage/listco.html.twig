{% extends 'base.html.twig' %}

{% block title %}Covoiturages{% endblock %}

{% block body %}
<div class="page-wrapper">
  <div class="section-box">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
      <h1 class="mb-0 d-flex align-items-center gap-2">
        <i data-lucide="car" style="width:28px;height:28px;stroke:var(--eco-secondary);"></i>
        Covoiturages disponibles
      </h1>
      {% if is_granted('IS_AUTHENTICATED_FULLY') and app.user.isConducteur %}
        <a href="{{ path('covoiturage_create') }}" class="btn btn-success">
          <i data-lucide="plus" class="icon-sm me-1"></i>Proposer un trajet
        </a>
      {% endif %}
    </div>

    {# ── Barre de recherche AJAX ── #}
    <form id="formRecherche" class="row g-3 align-items-end mb-4">
      <div class="col-sm-6 col-md-4 col-lg-2">
        <label class="form-label small fw-semibold">
          <i data-lucide="map-pin" class="icon-xs me-1"></i>Départ
        </label>
        <input type="text" id="depart" name="depart" class="form-control" placeholder="Ville de départ">
      </div>
      <div class="col-sm-6 col-md-4 col-lg-2">
        <label class="form-label small fw-semibold">
          <i data-lucide="map-pin" class="icon-xs me-1"></i>Arrivée
        </label>
        <input type="text" id="arrivee" name="arrivee" class="form-control" placeholder="Ville d'arrivée">
      </div>
      <div class="col-sm-6 col-md-4 col-lg-2">
        <label class="form-label small fw-semibold">
          <i data-lucide="calendar" class="icon-xs me-1"></i>Date
        </label>
        <input type="date" id="date" name="date" class="form-control">
      </div>
      <div class="col-sm-6 col-md-4 col-lg-2">
        <label class="form-label small fw-semibold">
          <i data-lucide="banknote" class="icon-xs me-1"></i>Prix max (€)
        </label>
        <input type="number" id="prix" name="prix" class="form-control" placeholder="Ex: 30">
      </div>
      <div class="col-sm-6 col-md-4 col-lg-2">
        <label class="form-label small fw-semibold">
          <i data-lucide="zap" class="icon-xs me-1"></i>Énergie
        </label>
        <select id="energie" name="energie" class="form-select">
          <option value="">Toutes</option>
          <option value="électrique">Électrique</option>
          <option value="essence">Essence</option>
          <option value="diesel">Diesel</option>
        </select>
      </div>
      <div class="col-sm-6 col-md-4 col-lg-2 d-flex align-items-end">
        <button type="submit" class="btn btn-success w-100">
          <i data-lucide="search" class="icon-sm me-1"></i>Rechercher
        </button>
      </div>
    </form>
    <div id="recentSearches"></div>
    <div id="loadingSpinner" class="d-none"></div>
    <div id="resultatsTrajets"></div>

    <hr class="my-4" style="border-color:var(--eco-border);">

    {% if covoiturages is empty %}
      <div class="text-center py-5">
        <i data-lucide="car" style="width:56px;height:56px;stroke:var(--eco-border);margin-bottom:1rem;"></i>
        <p class="text-muted fs-5">Aucun covoiturage disponible pour le moment.</p>
        <a href="{{ path('index') }}#recherche" class="btn btn-outline-success mt-2">
          <i data-lucide="search" class="icon-sm me-1"></i>Faire une recherche
        </a>
      </div>
    {% else %}
      <div class="row g-4">
        {% for covoiturage in covoiturages %}
          <div class="col-md-6 col-xl-4">
            <a href="{{ path('covoiturage_show', {'id': covoiturage.id}) }}" class="text-decoration-none">
              <div class="card h-100 hover-shadow-sm">
                <div class="card-body p-4">
                  <div class="d-flex justify-content-between align-items-start mb-3">
                    <h5 class="card-title mb-0">
                      {{ covoiturage.lieuDepart }}
                      <span style="color: var(--eco-secondary);">→</span>
                      {{ covoiturage.lieuArrivee }}
                    </h5>
                    {% if covoiturage.voiture.energie == 'électrique' %}
                      <span class="badge-eco ms-2 flex-shrink-0 d-flex align-items-center gap-1">
                        <i data-lucide="zap" style="width:12px;height:12px;stroke:var(--eco-primary);fill:var(--eco-primary);"></i>Éco
                      </span>
                    {% endif %}
                  </div>

                  <ul class="list-unstyled mb-3" style="font-size: 0.9rem; color: var(--eco-text-muted);">
                    <li class="mb-2 d-flex align-items-center gap-2">
                      <i data-lucide="calendar" class="icon-sm flex-shrink-0"></i>
                      {{ covoiturage.dateDepart|date('d/m/Y') }} à {{ covoiturage.heureDepart|date('H:i') }}
                    </li>
                    <li class="mb-2 d-flex align-items-center gap-2">
                      <i data-lucide="car" class="icon-sm flex-shrink-0"></i>
                      {{ covoiturage.voiture.modele ?? 'Véhicule non spécifié' }}
                    </li>
                    <li class="mb-2 d-flex align-items-center gap-2">
                      <i data-lucide="user" class="icon-sm flex-shrink-0"></i>
                      {{ covoiturage.createdBy.firstname }} {{ covoiturage.createdBy.lastname }}
                    </li>
                    <li class="d-flex align-items-center gap-2">
                      <i data-lucide="users" class="icon-sm flex-shrink-0"></i>
                      {{ covoiturage.nbPlace }} place{{ covoiturage.nbPlace > 1 ? 's' : '' }} restante{{ covoiturage.nbPlace > 1 ? 's' : '' }}
                    </li>
                  </ul>

                  <div class="d-flex justify-content-between align-items-center pt-2" style="border-top: 1px solid var(--eco-border);">
                    <span style="font-size: 1.1rem; font-weight: 600; color: var(--eco-primary);">
                      {{ covoiturage.prixPersonne }} €
                    </span>
                    <span class="btn btn-outline-success btn-sm">
                      Voir le trajet <i data-lucide="arrow-right" class="icon-xs ms-1"></i>
                    </span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>
{% endblock %}
