{% extends 'base.html.twig' %}

{% block title %}{{ covoiturage.lieuDepart }} → {{ covoiturage.lieuArrivee }}{% endblock %}

{% block body %}
<div class="page-wrapper">

  {# Fil d'ariane #}
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="{{ path('index') }}" style="color: var(--eco-secondary);">Accueil</a></li>
      <li class="breadcrumb-item"><a href="{{ path('covoiturage_list') }}" style="color: var(--eco-secondary);">Covoiturages</a></li>
      <li class="breadcrumb-item active">{{ covoiturage.lieuDepart }} → {{ covoiturage.lieuArrivee }}</li>
    </ol>
  </nav>

  <div class="row g-4">

    {# Colonne principale #}
    <div class="col-lg-8">

      {# Header trajet #}
      <div class="card p-4 mb-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
          <h1 class="mb-0" style="font-size: 1.8rem;">
            {{ covoiturage.lieuDepart }}
            <span style="color: var(--eco-secondary);">→</span>
            {{ covoiturage.lieuArrivee }}
          </h1>
          {% if covoiturage.voiture.energie == 'électrique' %}
            <span class="badge-eco">🌿 Trajet écologique</span>
          {% endif %}
        </div>

        <div class="row g-3">
          <div class="col-sm-6">
            <div class="p-3 rounded" style="background: var(--eco-surface-2); border: 1px solid var(--eco-border);">
              <div class="small text-muted mb-1">Départ</div>
              <div class="fw-semibold">{{ covoiturage.lieuDepart }}</div>
              <div style="color: var(--eco-primary);">{{ covoiturage.dateDepart|date('d/m/Y') }} à {{ covoiturage.heureDepart|date('H:i') }}</div>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="p-3 rounded" style="background: var(--eco-surface-2); border: 1px solid var(--eco-border);">
              <div class="small text-muted mb-1">Arrivée</div>
              <div class="fw-semibold">{{ covoiturage.lieuArrivee }}</div>
              <div style="color: var(--eco-primary);">{{ covoiturage.dateArrivee|date('d/m/Y') }} à {{ covoiturage.heureArrivee|date('H:i') }}</div>
            </div>
          </div>
        </div>
      </div>

      {# Véhicule #}
      <div class="card p-4 mb-4">
        <h3 class="mb-3">🚘 Véhicule</h3>
        <div class="row g-2">
          <div class="col-6"><span class="text-muted small">Modèle</span><div class="fw-semibold">{{ covoiturage.voiture.modele }}</div></div>
          <div class="col-6"><span class="text-muted small">Immatriculation</span><div class="fw-semibold">{{ covoiturage.voiture.immatriculation }}</div></div>
          <div class="col-6 mt-2"><span class="text-muted small">Énergie</span>
            <div class="fw-semibold">
              {% if covoiturage.voiture.energie == 'électrique' %}
                <span style="color: var(--eco-secondary);">⚡ Électrique</span>
              {% else %}
                {{ covoiturage.voiture.energie|capitalize }}
              {% endif %}
            </div>
          </div>
        </div>
      </div>

      {# Avis conducteur #}
      <div class="card p-4">
        <h3 class="mb-3">⭐ Avis sur le conducteur</h3>
        {% if avis_conducteur is not empty %}
          <div class="d-flex flex-column gap-3">
            {% for avis in avis_conducteur %}
              <div class="p-3 rounded" style="background: var(--eco-surface-2); border: 1px solid var(--eco-border);">
                <div class="fw-semibold mb-1">
                  {% for i in 1..5 %}
                    <span style="color: {{ i <= avis.note ? '#f59e0b' : 'var(--eco-border)' }};">★</span>
                  {% endfor %}
                  {{ avis.note }}/5
                </div>
                <p class="mb-0 fst-italic text-muted">"{{ avis.commentaire }}"</p>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="text-muted mb-0">Aucun avis pour ce conducteur.</p>
        {% endif %}
      </div>

      {# Formulaire avis #}
      {% if is_granted('IS_AUTHENTICATED_FULLY') and app.user in covoiturage.participants %}
        <div class="card p-4 mt-4">
          <h4 class="mb-3">📝 Laisser un avis</h4>
          {{ form_start(formAvis) }}
            {{ form_row(formAvis.note) }}
            {{ form_row(formAvis.commentaire) }}
            <button class="btn btn-success mt-2">Envoyer mon avis</button>
          {{ form_end(formAvis) }}
        </div>
      {% endif %}

    </div>

    {# Sidebar #}
    <div class="col-lg-4">

      {# Réservation #}
      <div class="card p-4 mb-4" style="position: sticky; top: 90px;">
        <h4 class="mb-3">📋 Réserver ce trajet</h4>
        <div class="d-flex justify-content-between mb-2">
          <span class="text-muted">Prix par personne</span>
          <span class="fw-bold fs-5" style="color: var(--eco-primary);">{{ covoiturage.prixPersonne }} €</span>
        </div>
        <div class="d-flex justify-content-between mb-3">
          <span class="text-muted">Places restantes</span>
          <span class="fw-semibold">{{ covoiturage.nbPlace }}</span>
        </div>
        <hr style="border-color: var(--eco-border);">

        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
          {% if app.user not in covoiturage.participants and app.user != covoiturage.createdBy %}
            <form method="post" action="{{ path('covoiturage_covoiturage_participer', {'id': covoiturage.id}) }}">
              <input type="hidden" name="_token" value="{{ csrf_token('participer' ~ covoiturage.id) }}">
              <button type="submit" class="btn btn-success w-100" {{ covoiturage.nbPlace <= 0 ? 'disabled' : '' }}>
                {{ covoiturage.nbPlace > 0 ? '✅ Participer (1 crédit)' : 'Complet' }}
              </button>
            </form>
          {% elseif app.user in covoiturage.participants %}
            <div class="alert alert-success mb-0 text-center">✔ Vous participez à ce trajet</div>
          {% else %}
            <div class="alert mb-0 text-center" style="background: var(--eco-surface-2); color: var(--eco-text-muted);">Vous êtes le conducteur</div>
          {% endif %}
        {% else %}
          <a href="{{ path('app_login') }}" class="btn btn-success w-100">🔐 Se connecter pour participer</a>
        {% endif %}
      </div>

      {# Conducteur #}
      <div class="card p-4">
        <h4 class="mb-3">👤 Conducteur</h4>
        {% if covoiturage.createdBy.photo %}
          <img src="data:image/jpeg;base64,{{ covoiturage.createdBy.photo|convert_base64 }}" class="rounded-circle mb-3 d-block mx-auto" width="80" height="80" style="object-fit:cover;">
        {% else %}
          <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width:80px;height:80px;background:var(--eco-mint);font-size:2rem;">👤</div>
        {% endif %}
        <div class="text-center">
          <div class="fw-semibold">{{ covoiturage.createdBy.firstname }} {{ covoiturage.createdBy.lastname }}</div>
          <div class="text-muted small">{{ covoiturage.createdBy.email }}</div>
        </div>
      </div>

    </div>
  </div>
</div>
{% endblock %}
