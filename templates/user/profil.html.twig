{% extends 'base.html.twig' %}

{% block title %}Dashboard — EcoRide{% endblock %}

{% block body %}
{% if not app.user %}
  <div class="page-wrapper">
    <div class="section-box text-center py-5">
      <i data-lucide="lock" style="width:48px;height:48px;stroke:var(--eco-border);margin-bottom:1rem;"></i>
      <p class="fs-5 text-muted mb-4">Connectez-vous pour accéder à votre espace.</p>
      <a href="{{ path('app_login') }}" class="btn btn-success px-5">
        <i data-lucide="log-in" class="icon-sm me-2"></i>Se connecter
      </a>
    </div>
  </div>
{% else %}
<div class="page-wrapper">

  {# ── HEADER DASHBOARD ── #}
  <div class="dashboard-header mb-4">
    <div class="d-flex align-items-center gap-3 flex-wrap">
      {% if app.user.photo %}
        <img src="data:image/jpeg;base64,{{ user.photo|convert_base64 }}"
             class="rounded-circle" style="width:64px;height:64px;object-fit:cover;border:3px solid rgba(255,255,255,0.4);">
      {% else %}
        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:64px;height:64px;background:rgba(255,255,255,0.15);border:3px solid rgba(255,255,255,0.4);">
          <i data-lucide="user" style="width:32px;height:32px;stroke:#fff;"></i>
        </div>
      {% endif %}
      <div>
        <h1 class="mb-0" style="font-size:1.7rem;">
          Bonjour, {{ app.user.firstname }}
        </h1>
        <p class="mb-0" style="font-size:0.9rem;color:rgba(255,255,255,0.75);">
          @{{ app.user.username }}
          {% if app.user.isConducteur %}
            &nbsp;·&nbsp;<span style="color:rgba(255,255,255,0.95);"><i data-lucide="car" style="width:14px;height:14px;stroke:currentColor;vertical-align:middle;"></i> Conducteur</span>
          {% endif %}
        </p>
      </div>
    </div>
  </div>

  {# ── STATS CARDS ── #}
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-2">
      <div class="stat-card">
        <i data-lucide="coins" style="width:26px;height:26px;stroke:var(--eco-secondary);margin-bottom:0.4rem;"></i>
        <div class="stat-card__value">{{ credit.amount ?? 0 }}</div>
        <div class="stat-card__label">Crédits</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card">
        <i data-lucide="route" style="width:26px;height:26px;stroke:var(--eco-secondary);margin-bottom:0.4rem;"></i>
        <div class="stat-card__value">{{ nombreTrajets }}</div>
        <div class="stat-card__label">Trajets proposés</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card">
        <i data-lucide="calendar" style="width:26px;height:26px;stroke:var(--eco-secondary);margin-bottom:0.4rem;"></i>
        <div class="stat-card__value">{{ nombreReservations }}</div>
        <div class="stat-card__label">Réservations</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card">
        <i data-lucide="star" style="width:26px;height:26px;stroke:#f59e0b;fill:#f59e0b;margin-bottom:0.4rem;"></i>
        <div class="stat-card__value">{{ noteMoyenne is not null ? noteMoyenne|number_format(1) : '—' }}</div>
        <div class="stat-card__label">Note moyenne</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card">
        <i data-lucide="leaf" style="width:26px;height:26px;stroke:#22c55e;margin-bottom:0.4rem;"></i>
        <div class="stat-card__value" style="color:#22c55e;">{{ (nombreReservations * 2.1)|number_format(0) }}</div>
        <div class="stat-card__label">kg CO₂ économisé</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="stat-card">
        <i data-lucide="trending-up" style="width:26px;height:26px;stroke:var(--eco-accent);margin-bottom:0.4rem;"></i>
        <div class="stat-card__value" style="color:var(--eco-accent);">{{ nombreTrajets + nombreReservations }}</div>
        <div class="stat-card__label">Total trajets</div>
      </div>
    </div>
  </div>

  {# ── CONTENU PRINCIPAL ── #}
  <div class="row g-4">

    {# Colonne principale #}
    <div class="col-lg-8">

      {# Actions rapides #}
      <div class="card p-4 mb-4">
        <h5 class="mb-3 d-flex align-items-center gap-2" style="color:var(--eco-primary);">
          <i data-lucide="zap" class="icon-md"></i>Actions rapides
        </h5>
        <div class="row g-2">
          {% if app.user.isConducteur %}
            <div class="col-6 col-sm-3">
              <a href="{{ path('covoiturage_create') }}" class="quick-action">
                <i data-lucide="plus-circle" style="width:28px;height:28px;stroke:var(--eco-primary);"></i>
                <span>Proposer un trajet</span>
              </a>
            </div>
            <div class="col-6 col-sm-3">
              <a href="{{ path('user_trajets') }}" class="quick-action">
                <i data-lucide="route" style="width:28px;height:28px;stroke:var(--eco-primary);"></i>
                <span>Mes trajets</span>
              </a>
            </div>
            <div class="col-6 col-sm-3">
              <a href="{{ path('voiture_create') }}" class="quick-action">
                <i data-lucide="car" style="width:28px;height:28px;stroke:var(--eco-primary);"></i>
                <span>Ajouter voiture</span>
              </a>
            </div>
          {% else %}
            <div class="col-6 col-sm-3">
              <a href="{{ path('covoiturage_list') }}" class="quick-action">
                <i data-lucide="search" style="width:28px;height:28px;stroke:var(--eco-primary);"></i>
                <span>Chercher trajet</span>
              </a>
            </div>
            <div class="col-6 col-sm-3">
              <a href="{{ path('user_become_conducteur') }}" class="quick-action"
                 onclick="return confirm('Devenir conducteur ?')">
                <i data-lucide="car" style="width:28px;height:28px;stroke:var(--eco-primary);"></i>
                <span>Devenir conducteur</span>
              </a>
            </div>
          {% endif %}
          <div class="col-6 col-sm-3">
            <a href="{{ path('user_reservations') }}" class="quick-action">
              <i data-lucide="calendar" style="width:28px;height:28px;stroke:var(--eco-primary);"></i>
              <span>Mes réservations</span>
            </a>
          </div>
          <div class="col-6 col-sm-3">
            <a href="{{ path('avis_list') }}" class="quick-action">
              <i data-lucide="star" style="width:28px;height:28px;stroke:var(--eco-primary);"></i>
              <span>Voir les avis</span>
            </a>
          </div>
        </div>
      </div>

      {# Trajets disponibles (passager) #}
      {% if not app.user.isConducteur and 'ROLE_ADMIN' not in app.user.roles %}
        <div class="card p-4 mb-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 d-flex align-items-center gap-2" style="color:var(--eco-primary);">
              <i data-lucide="globe" class="icon-md"></i>Trajets disponibles
            </h5>
            <a href="{{ path('covoiturage_list') }}" style="font-size:0.85rem;color:var(--eco-secondary);">
              Voir tout <i data-lucide="arrow-right" class="icon-xs"></i>
            </a>
          </div>
          {% if all_covoiturages is empty %}
            <p class="text-muted mb-0">Aucun trajet disponible pour le moment.</p>
          {% else %}
            <div class="d-flex flex-column gap-2">
              {% for trajet in all_covoiturages|slice(0, 5) %}
                <div class="trip-row">
                  <div class="trip-info">
                    <div class="fw-semibold">{{ trajet.lieuDepart }} → {{ trajet.lieuArrivee }}</div>
                    <div class="text-muted" style="font-size:0.82rem;">{{ trajet.dateDepart|date('d/m/Y') }} · {{ trajet.prixPersonne }} €</div>
                  </div>
                  <form method="post" action="{{ path('covoiturage_covoiturage_participer', {'id': trajet.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('participer' ~ trajet.id) }}">
                    <button type="submit" class="btn btn-sm btn-success d-flex align-items-center gap-1">
                      <i data-lucide="coins" style="width:14px;height:14px;stroke:#fff;"></i>1
                    </button>
                  </form>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# Covoiturages conducteur #}
      {% if app.user.isConducteur %}
        <div class="card p-4 mb-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 d-flex align-items-center gap-2" style="color:var(--eco-primary);">
              <i data-lucide="route" class="icon-md"></i>Mes derniers trajets
            </h5>
            <a href="{{ path('user_trajets') }}" style="font-size:0.85rem;color:var(--eco-secondary);">
              Voir tout <i data-lucide="arrow-right" class="icon-xs"></i>
            </a>
          </div>
          {% if covoiturages is empty %}
            <p class="text-muted mb-0">Aucun trajet proposé.</p>
            <a href="{{ path('covoiturage_create') }}" class="btn btn-success btn-sm mt-3">
              <i data-lucide="plus" class="icon-sm me-1"></i>Proposer mon premier trajet
            </a>
          {% else %}
            <div class="d-flex flex-column gap-2">
              {% for cov in covoiturages|slice(0, 5) %}
                <div class="trip-row">
                  <div class="trip-info">
                    <div class="fw-semibold">{{ cov.lieuDepart }} → {{ cov.lieuArrivee }}</div>
                    <div class="text-muted" style="font-size:0.82rem;">{{ cov.dateDepart|date('d/m/Y') }}</div>
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge-eco" style="font-size:0.75rem;">{{ cov.statut.value }}</span>
                    <a href="{{ path('covoiturage_edit', {'id': cov.id}) }}" class="btn btn-sm btn-outline-primary">
                      <i data-lucide="pencil" class="icon-xs"></i>
                    </a>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {# Voitures #}
        <div class="card p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 d-flex align-items-center gap-2" style="color:var(--eco-primary);">
              <i data-lucide="car" class="icon-md"></i>Mes voitures
            </h5>
            <a href="{{ path('voiture_create') }}" class="btn btn-success btn-sm">
              <i data-lucide="plus" class="icon-sm me-1"></i>Ajouter
            </a>
          </div>
          {% if voitures is empty %}
            <p class="text-muted mb-0">Aucune voiture enregistrée.</p>
          {% else %}
            <div class="d-flex flex-column gap-2">
              {% for voiture in voitures %}
                <div class="trip-row">
                  <div class="trip-info">
                    <div class="fw-semibold">{{ voiture.modele }}</div>
                    <div class="text-muted" style="font-size:0.82rem;">{{ voiture.immatriculation }} · {{ voiture.energie }}</div>
                  </div>
                  <div class="d-flex gap-2">
                    <a href="{{ path('voiture_edit', {'id': voiture.id}) }}" class="btn btn-sm btn-outline-primary">
                      <i data-lucide="pencil" class="icon-xs"></i>
                    </a>
                    <a href="{{ path('voiture_delete', {'id': voiture.id}) }}" class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Supprimer ?')">
                      <i data-lucide="trash-2" class="icon-xs"></i>
                    </a>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}

    </div>

    {# Sidebar #}
    <div class="col-lg-4">

      {# Profil card #}
      <div class="card p-4 mb-4">
        <h5 class="mb-3 d-flex align-items-center gap-2" style="color:var(--eco-primary);">
          <i data-lucide="clipboard-list" class="icon-md"></i>Mon profil
        </h5>
        <ul class="list-unstyled mb-0" style="font-size:0.88rem;">
          <li class="profile-row">
            <span class="text-muted">Email</span>
            <span class="fw-semibold text-truncate">{{ app.user.email }}</span>
          </li>
          <li class="profile-row">
            <span class="text-muted">Téléphone</span>
            <span class="fw-semibold">{{ app.user.telephone }}</span>
          </li>
          <li class="profile-row">
            <span class="text-muted">Adresse</span>
            <span class="fw-semibold">{{ app.user.adresse }}</span>
          </li>
          <li class="profile-row" style="border:none;">
            <span class="text-muted">Naissance</span>
            <span class="fw-semibold">{{ app.user.dateNaissance|date('d/m/Y') }}</span>
          </li>
        </ul>
      </div>

      {# Crédits card #}
      <div class="card p-4 mb-4 text-center">
        <i data-lucide="coins" style="width:40px;height:40px;stroke:var(--eco-secondary);margin-bottom:0.5rem;"></i>
        <div style="font-size:2.4rem;font-weight:700;color:var(--eco-primary);">{{ credit.amount ?? 0 }}</div>
        <div class="text-muted mb-3">crédits disponibles</div>
        <div class="progress" style="height:8px;background:var(--eco-border);border-radius:4px;">
          {% set creditPct = (credit.amount ?? 0) * 5 %}
          {% set creditPct = creditPct > 100 ? 100 : creditPct %}
          <div class="progress-bar" style="width:{{ creditPct }}%;background:linear-gradient(90deg,var(--eco-secondary),var(--eco-primary));border-radius:4px;"></div>
        </div>
        <div class="text-muted mt-2" style="font-size:0.78rem;">1 crédit = 1 trajet</div>
      </div>

      {# Statut conducteur #}
      {% if not app.user.isConducteur %}
        <div class="card p-4 text-center" style="border-top-color: #f59e0b;">
          <i data-lucide="car" style="width:40px;height:40px;stroke:#f59e0b;margin-bottom:0.5rem;"></i>
          <h6 class="mt-2 mb-2">Devenez conducteur</h6>
          <p class="text-muted mb-3" style="font-size:0.85rem;">Proposez vos propres trajets et gagnez des crédits.</p>
          <form method="post" action="{{ path('user_become_conducteur') }}">
            <button class="btn btn-success w-100">
              <i data-lucide="car" class="icon-sm me-2"></i>Devenir conducteur
            </button>
          </form>
        </div>
      {% else %}
        <div class="card p-4 text-center" style="border-top-color: var(--eco-secondary);">
          <i data-lucide="check-circle" style="width:40px;height:40px;stroke:var(--eco-secondary);margin-bottom:0.5rem;"></i>
          <h6 class="mt-2 mb-1">Conducteur actif</h6>
          <p class="text-muted mb-3" style="font-size:0.85rem;">
            {{ nombreTrajets }} trajet{{ nombreTrajets > 1 ? 's' : '' }} proposé{{ nombreTrajets > 1 ? 's' : '' }}
          </p>
          <a href="{{ path('covoiturage_create') }}" class="btn btn-success w-100">
            <i data-lucide="plus" class="icon-sm me-2"></i>Nouveau trajet
          </a>
        </div>
      {% endif %}

    </div>
  </div>
</div>
{% endif %}
{% endblock %}
