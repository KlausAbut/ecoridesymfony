{% extends 'base.html.twig' %}

{% block title %}Inscription — EcoRide{% endblock %}

{% block body %}
<div class="page-wrapper d-flex align-items-center justify-content-center" style="min-height: 80vh;">
  <div style="width: 100%; max-width: 640px;">

    <div class="text-center mb-4">
      <div style="font-size: 2.5rem;">🌿</div>
      <h1 style="font-size: 1.8rem;" class="mb-1">Créer un compte</h1>
      <p class="text-muted">Rejoignez la communauté EcoRide</p>
    </div>

    <div class="card p-4"
         x-data="{
           password: '',
           strength() {
             if (this.password.length === 0) return 0;
             if (this.password.length < 6) return 1;
             if (this.password.length < 10) return 2;
             return 3;
           },
           strengthLabel() {
             return ['', 'Faible', 'Moyen', 'Fort'][this.strength()];
           },
           strengthColor() {
             return ['', '#ef4444', '#f59e0b', 'var(--eco-secondary)'][this.strength()];
           }
         }">

      {{ form_start(registrationForm) }}

      <div class="row g-3 mb-3">
        <div class="col-sm-6">
          <label class="form-label fw-semibold">Prénom</label>
          {{ form_widget(registrationForm.firstname, {'attr': {'class': 'form-control', 'placeholder': 'Jean'}}) }}
          {{ form_errors(registrationForm.firstname) }}
        </div>
        <div class="col-sm-6">
          <label class="form-label fw-semibold">Nom</label>
          {{ form_widget(registrationForm.lastname, {'attr': {'class': 'form-control', 'placeholder': 'Dupont'}}) }}
          {{ form_errors(registrationForm.lastname) }}
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Nom d'utilisateur</label>
        {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control', 'placeholder': '@jean_dupont'}}) }}
        {{ form_errors(registrationForm.username) }}
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Adresse e-mail</label>
        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'jean@example.com'}}) }}
        {{ form_errors(registrationForm.email) }}
      </div>

      <div class="row g-3 mb-3">
        <div class="col-sm-6">
          <label class="form-label fw-semibold">Téléphone</label>
          {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-control', 'placeholder': '06 12 34 56 78'}}) }}
          {{ form_errors(registrationForm.telephone) }}
        </div>
        <div class="col-sm-6">
          <label class="form-label fw-semibold">Date de naissance</label>
          {{ form_widget(registrationForm.date_naissance, {'attr': {'class': 'form-control'}}) }}
          {{ form_errors(registrationForm.date_naissance) }}
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Adresse</label>
        {{ form_widget(registrationForm.adresse, {'attr': {'class': 'form-control', 'placeholder': '12 rue des Lilas, Paris'}}) }}
        {{ form_errors(registrationForm.adresse) }}
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Mot de passe</label>
        {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'x-model': 'password'}}) }}
        {{ form_errors(registrationForm.plainPassword) }}
        <div class="mt-2" x-show="password.length > 0">
          <div style="height: 4px; border-radius: 2px; background: var(--eco-border); overflow: hidden;">
            <div :style="`width: ${strength() * 33.3}%; background: ${strengthColor()}; height: 100%; transition: width 0.3s ease;`"></div>
          </div>
          <div class="small mt-1" :style="`color: ${strengthColor()};`" x-text="strengthLabel()"></div>
        </div>
      </div>

      <div class="d-flex align-items-center gap-2 mb-4 p-3 rounded" style="background: var(--eco-mint); border: 1px solid var(--eco-light);">
        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input flex-shrink-0', 'style': 'margin-top:0;'}}) }}
        {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'mb-0', 'style': 'font-size:0.88rem;cursor:pointer;'}}) }}
        {{ form_errors(registrationForm.agreeTerms) }}
      </div>

      <button type="submit" class="btn btn-success w-100 py-2" style="font-size: 1rem;">
        Créer mon compte 🌿
      </button>

      {{ form_end(registrationForm) }}

      <p class="text-center mt-4 mb-0" style="font-size: 0.9rem;">
        Déjà inscrit ?
        <a href="{{ path('app_login') }}" style="color: var(--eco-primary); font-weight: 500;">Se connecter</a>
      </p>
    </div>

  </div>
</div>
{% endblock %}
