{% extends 'base.html.twig' %}

{% block title %}Page introuvable — EcoRide{% endblock %}

{% block body %}
<div class="page-wrapper">
  <div class="section-box text-center py-5" style="min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;">
    <div style="font-size:5rem;font-weight:800;color:var(--eco-secondary);line-height:1;margin-bottom:0.5rem;">404</div>
    <i data-lucide="map-off" style="width:56px;height:56px;stroke:var(--eco-border);margin-bottom:1.5rem;"></i>
    <h1 class="mb-2" style="font-size:1.6rem;color:var(--eco-text);">Cette page n'existe pas</h1>
    <p class="text-muted mb-4" style="max-width:400px;">
      Le trajet que vous cherchez semble avoir pris un autre chemin. Pas de panique, retournez à l'accueil !
    </p>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
      <a href="{{ path('index') }}" class="btn btn-success px-4">
        <i data-lucide="home" class="icon-sm me-2"></i>Retour à l'accueil
      </a>
      <a href="{{ path('index') }}#recherche" class="btn btn-outline-success px-4">
        <i data-lucide="search" class="icon-sm me-2"></i>Chercher un trajet
      </a>
    </div>
  </div>
</div>
{% endblock %}
