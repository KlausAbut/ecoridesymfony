    <div class="d-none d-lg-flex w-100 align-items-center">

      <ul class="navbar-nav mx-auto mb-0 flex-row gap-2">
        <li class="nav-item">
          <a class="nav-link px-3 py-2 rounded" href="{{ path('index') }}">Accueil</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-3 py-2 rounded" href="{{ path('covoiturage_list') }}">Covoiturages</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-3 py-2 rounded" href="{{ path('contact') }}">Contact</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-3 py-2 rounded" href="{{ path('about') }}">À propos</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-3 py-2 rounded" href="{{ path('avis_list') }}">Avis</a>
        </li>
      </ul>

      <ul class="navbar-nav ms-auto">
        {% if app.user %}
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle px-3 py-2 rounded"
              href="#"
              id="userDropdownDesktop"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              👤 Mon compte
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdownDesktop">
              {% if 'ROLE_ADMIN' in app.user.roles %}
                <li>
                  <a class="dropdown-item" href="{{ path('admin_dashboard') }}">⚙️ Admin</a>
                </li>
              {% elseif 'ROLE_EMPLOYE' in app.user.roles %}
                <li>
                  <a class="dropdown-item" href="{{ path('employe_moderation') }}">🛠️ Employé</a>
                </li>
              {% else %}
                <li>
                  <a class="dropdown-item" href="{{ path('user_profile') }}">👤 Mon profil</a>
                </li>
                <li>
                  <a class="dropdown-item" href="{{ path('user_reservations') }}">📋 Mes réservations</a>
                </li>
                <li>
                  <a class="dropdown-item" href="{{ path('user_trajets') }}">🚗 Mes trajets</a>
                </li>
              {% endif %}
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">🚪 Déconnexion</a>
              </li>
            </ul>
          </li>
        {% else %}
          <li class="nav-item me-2">
            <a class="btn btn-outline-light btn-sm" href="{{ path('app_login') }}">Connexion</a>
